{
  "name": "pixel-blog",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "Embeddable pixel-art blog plugin with Shadow DOM isolation",
  "main": "dist/pixel-blog.umd.js",
  "module": "dist/pixel-blog.es.js",
  "types": "dist/types.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run build:lib && npm run build:standalone",
    "build:lib": "BUILD_MODE=lib vite build",
    "build:standalone": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "framer-motion": "^11.0.8",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.35",
    "typescript": "^5.2.2",
    "vite": "^5.1.6"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "keywords": [
    "blog",
    "pixel-art",
    "retro",
    "plugin",
    "embeddable",
    "react",
    "shadow-dom"
  ]
}
